  dialogue:
    dialogueLines:
    - character:
        name: Novar
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 0
      line: "You\u2019ve been at that table for hours."
    - character:
        name: Nerd Girl
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 1
      line: "Oh\u2014! Please don\u2019t talk so loud\u2026"
    - character:
        name: Novar
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 1
      line: Sorry. What are you reading?
    - character:
        name: Nerd Girl
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 1
      line: "Sci-fi. It\u2019s\u2026 dense. Most people don\u2019t get into it."
    - character:
        name: Novar
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 1
      line: "Maybe I\u2019m not most people."
    - character:
        name: Nerd Girl
        icon: {fileID: 0}
      backGroundImage: {fileID: 0}
      onTheRight: 1
      line: "\u2026Then sit. Just\u2014quietly."
