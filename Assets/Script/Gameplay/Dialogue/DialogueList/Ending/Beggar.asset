  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb9780490a24f1442b95ae6bb67dfcab, type: 3}
  m_Name: Beggar
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Beggar
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "Ten years have passed. You sit alone on a cracked stairway, counting
        loose coins in your palm. The city moves around you, indifferent. Expensive
        nights, endless parties, and the need to keep up appearances slowly drained
        everything you earned. Money came in\u2014but it never stayed."
    - character:
        name: Beggar
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: You ignored the warnings. Debt replaced savings. Pleasure replaced planning.
        By the time you noticed, there was nothing left to recover.
    - character:
        name: Beggar
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "The old watch hangs from your fingers, still ticking.\L Ten years ago,
        you were given a chance to change your life.\L You spent it."
  dialogueChoices: []
