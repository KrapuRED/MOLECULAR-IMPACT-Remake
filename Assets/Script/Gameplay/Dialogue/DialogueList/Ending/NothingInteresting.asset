  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb9780490a24f1442b95ae6bb67dfcab, type: 3}
  m_Name: NothingInteresting
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Nothing Interesting
        icon: {fileID: -2052070399228182314, guid: e8d07112930c8fc4eafb843da7db22b4, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "Ten years have passed. You sit at the same office desk, under the same
        white lights, surrounded by the quiet hum of routine. The work gets done.
        The days move forward. Nothing feels particularly wrong\u2014yet nothing
        feels meaningful either."
    - character:
        name: Nothing Interesting
        icon: {fileID: -2052070399228182314, guid: e8d07112930c8fc4eafb843da7db22b4, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: The watch rests in your drawer, ticking softly between stacks of paperwork.
        You made safe choices. You avoided disaster. But safety alone never led you
        anywhere new.
    - character:
        name: Nothing Interesting
        icon: {fileID: -2052070399228182314, guid: e8d07112930c8fc4eafb843da7db22b4, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: Ten years ago, you were given a chance to change your life. In the end,
        you simply learned how to endure it.
  dialogueChoices: []
