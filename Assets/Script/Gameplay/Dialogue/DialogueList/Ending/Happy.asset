  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb9780490a24f1442b95ae6bb67dfcab, type: 3}
  m_Name: Happy
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Happy
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: 7838683145625251734, guid: 05fac6660299b31459998fce9f7611a7, type: 3}
      onTheRight: 0
      line: "Ten years have passed. You stand in an open field as the sun sinks low,
        painting the sky in warm colors. Silhouettes move beside you\u2014people
        whose presence you earned through time, care, and consistency. Nothing here
        was rushed. Nothing was taken for granted."
    - character:
        name: Happy
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: 7838683145625251734, guid: 05fac6660299b31459998fce9f7611a7, type: 3}
      onTheRight: 0
      line: "Your body feels steady. Your mind feels at peace. The life before you
        was shaped by the habits you chose when no one was watching\u2014small, quiet
        decisions that slowly became a good life."
    - character:
        name: Happy
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: 7838683145625251734, guid: 05fac6660299b31459998fce9f7611a7, type: 3}
      onTheRight: 0
      line: "The old watch rests in your pocket, still ticking, but no longer heavy.\L
        This time, the future feels right."
  dialogueChoices: []
