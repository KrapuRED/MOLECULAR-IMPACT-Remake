MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb9780490a24f1442b95ae6bb67dfcab, type: 3}
  m_Name: DepressionEnding
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Deppresion Ending
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "Ten years have passed. You stand once again at the edge of the same
        skyscraper. The city below glows just as it did before\u2014but the weight
        in your chest feels heavier now. Time moved forward, yet your life remained
        trapped in familiar patterns. Small choices, repeated without thought, quietly
        led you back here."
    - character:
        name: Deppresion Ending
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "The old watch rests in your palm, cold and unmoving. The chance you
        were given was real. So were your decisions. In the end, nothing forced you
        to fail\u2014you simply became what your habits shaped. "
    - character:
        name: Deppresion Ending
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      onTheRight: 0
      line: "Time gave you a second chance\u2026 but it was never time that needed
        to change."
  dialogueChoices:
  - {fileID: 0}
