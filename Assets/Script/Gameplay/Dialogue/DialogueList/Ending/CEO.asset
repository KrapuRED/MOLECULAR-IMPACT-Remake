  m_Script: {fileID: 11500000, guid: bb9780490a24f1442b95ae6bb67dfcab, type: 3}
  m_Name: CEO
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: CEO
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -3113753526686159144, guid: 31daf87e9c20b714f9180ed5f723d500, type: 3}
      onTheRight: 0
      line: Ten years have passed. You stand at the top floor of a glass tower, the
        city stretching beneath you. This life was not built overnight. Long evenings
        of focused work, steady learning, and disciplined routines slowly compounded
        into something real. You chose growth when shortcuts were easier.
    - character:
        name: CEO
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -3113753526686159144, guid: 31daf87e9c20b714f9180ed5f723d500, type: 3}
      onTheRight: 0
      line: Surrounded by people who valued knowledge and ambition, you sharpened
        your thinking and invested in yourself. Money followed effort. Opportunity
        followed preparation.
    - character:
        name: CEO
        icon: {fileID: -681178344135522496, guid: 7a20e9ef1e160f14c99b5991eb9f9b04, type: 3}
      backGroundImage: {fileID: -3113753526686159144, guid: 31daf87e9c20b714f9180ed5f723d500, type: 3}
      onTheRight: 0
      line: "The old watch rests in your pocket, still ticking\u2014no longer a symbol
        of regret, but of patience.\nTen years ago, you were given a chance to change
        your life.\nYou built it."
  dialogueChoices: []
